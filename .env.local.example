# --- クライアント(ブラウザ)に公開される値 ---
# Supabase の Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# --- サーバー専用(絶対にブラウザに出さない / NEXT_PUBLIC を付けない) ---
# 管理者ログインのパスワード(自分で好きな文字列を決める)
ADMIN_PASSWORD=change-me-to-a-strong-password
# セッション署名用のランダム文字列(例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SESSION_SECRET=replace-with-a-random-secret
# Supabase の service_role / secret キー(sb_secret_... または service_role の JWT)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here
